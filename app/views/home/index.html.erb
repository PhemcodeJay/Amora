<div class="min-h-screen bg-gradient-to-br from-pink-100 to-purple-100">
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-16">
    <div class="text-center">
      <h1 class="text-5xl font-bold text-gray-800 mb-4">Find Your Perfect Match</h1>
      <p class="text-xl text-gray-600 mb-8">Connect with people who share your interests and values</p>
      
      <% unless user_signed_in? %>
        <div class="space-x-4">
          <%= link_to "Sign Up", new_user_registration_path, class: "bg-pink-500 text-white px-8 py-3 rounded-full text-lg font-semibold hover:bg-pink-600 transition" %>
          <%= link_to "Log In", new_user_session_path, class: "bg-white text-pink-500 px-8 py-3 rounded-full text-lg font-semibold hover:bg-gray-100 transition" %>
        </div>
      <% end %>
    </div>
    
    <!-- Features -->
    <div class="grid md:grid-cols-3 gap-8 mt-16">
      <% @features.each do |feature| %>
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-pink-500 text-4xl mb-4">❤️</div>
          <h3 class="text-xl font-semibold mb-2"><%= feature[:title] %></h3>
          <p class="text-gray-600"><%= feature[:description] %></p>
        </div>
      <% end %>
    </div>
    
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-8 mt-16 text-center">
      <div>
        <div class="text-3xl font-bold text-pink-500">10K+</div>
        <div class="text-gray-600">Active Users</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-pink-500">5K+</div>
        <div class="text-gray-600">Matches Made</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-pink-500">50K+</div>
        <div class="text-gray-600">Messages Sent</div>
      </div>
    </div>
  </div>
</div>