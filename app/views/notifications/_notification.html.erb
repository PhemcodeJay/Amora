<div class="px-4 py-3 hover:bg-gray-50 border-b last:border-b-0 <%= 'bg-pink-50' unless notification.read %>">
  <div class="flex items-start space-x-3">
    <div class="flex-shrink-0">
      <% case notification.notification_type %>
      <% when 'like' %>
        <span class="text-2xl">❤️</span>
      <% when 'match' %>
        <span class="text-2xl">✨</span>
      <% when 'message' %>
        <span class="text-2xl">💬</span>
      <% end %>
    </div>
    
    <div class="flex-1 min-w-0">
      <p class="text-sm text-gray-900"><%= notification.content %></p>
      <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(notification.created_at) %> ago</p>
    </div>
    
    <% unless notification.read %>
      <div class="w-2 h-2 bg-pink-500 rounded-full"></div>
    <% end %>
  </div>
</div>