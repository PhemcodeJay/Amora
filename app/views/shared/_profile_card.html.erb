<div class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition">
  <!-- Photo -->
  <div class="relative">
    <% if profile.photo? %>
      <%= image_tag profile.photo.url(:medium), class: "w-full h-48 object-cover" %>
    <% else %>
      <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
        <span class="text-gray-400 text-4xl">📷</span>
      </div>
    <% end %>
    
    <!-- Age Badge -->
    <div class="absolute bottom-2 left-2 bg-black bg-opacity-50 text-white px-2 py-1 rounded text-sm">
      <%= profile.age %> years
    </div>
  </div>
  
  <!-- Content -->
  <div class="p-4">
    <div class="flex justify-between items-start mb-2">
      <h3 class="text-lg font-semibold"><%= profile.name %></h3>
      <span class="text-sm text-gray-500">📍 <%= profile.location %></span>
    </div>
    
    <!-- Bio -->
    <p class="text-gray-600 text-sm mb-3 line-clamp-2"><%= profile.bio.truncate(100) %></p>
    
    <!-- Interests -->
    <div class="flex flex-wrap gap-1 mb-3">
      <% profile.interests.limit(3).each do |interest| %>
        <span class="bg-pink-100 text-pink-800 text-xs px-2 py-1 rounded"><%= interest.name %></span>
      <% end %>
      <% if profile.interests.count > 3 %>
        <span class="text-xs text-gray-500">+<%= profile.interests.count - 3 %> more</span>
      <% end %>
    </div>
    
    <!-- Compatibility Score (optional) -->
    <% if defined?(score) %>
      <div class="mb-3">
        <div class="flex justify-between text-sm mb-1">
          <span>Compatibility</span>
          <span><%= score %>%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-pink-500 rounded-full h-2" style="width: <%= score %>%"></div>
        </div>
      </div>
    <% end %>
    
    <!-- Actions -->
    <div class="flex justify-between mt-4">
      <%= button_to likes_path(user_id: profile.user_id), method: :post, class: "bg-pink-500 text-white px-4 py-2 rounded text-sm hover:bg-pink-600" do %>
        <span class="flex items-center space-x-1">
          <span>❤️</span>
          <span>Like</span>
        </span>
      <% end %>
      
      <%= link_to "View Profile", profile_path(profile), class: "border border-pink-500 text-pink-500 px-4 py-2 rounded text-sm hover:bg-pink-50" %>
    </div>
  </div>
</div>