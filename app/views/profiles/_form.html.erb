<%= form_with(model: @profile, local: true, class: "space-y-6") do |f| %>
  <% if @profile.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
      <h2><%= pluralize(@profile.errors.count, "error") %> prohibited this profile from being saved:</h2>
      <ul class="list-disc ml-5 mt-2">
        <% @profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <!-- Photo Upload -->
  <div>
    <label class="block text-sm font-medium text-gray-700">Profile Photo</label>
    <div class="mt-1 flex items-center space-x-4">
      <% if @profile.photo? %>
        <div class="relative">
          <%= image_tag @profile.photo.url(:medium), class: "w-24 h-24 rounded-full object-cover" %>
          <button type="button" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm hover:bg-red-600" onclick="document.getElementById('remove_photo').value='true'">×</button>
        </div>
      <% end %>
      <%= f.file_field :photo, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100" %>
    </div>
    <%= hidden_field_tag :remove_photo, false %>
  </div>
  
  <!-- Basic Info -->
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700">Name</label>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500" %>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Age</label>
      <%= f.number_field :age, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500", min: 18, max: 100 %>
    </div>
  </div>
  
  <!-- Location -->
  <div>
    <label class="block text-sm font-medium text-gray-700">Location</label>
    <%= f.text_field :location, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500", placeholder: "City, Country" %>
  </div>
  
  <!-- Bio -->
  <div>
    <label class="block text-sm font-medium text-gray-700">Bio</label>
    <%= f.text_area :bio, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500", placeholder: "Tell us about yourself..." %>
  </div>
  
  <!-- Gender and Looking For -->
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700">I am</label>
      <%= f.select :gender, options_for_select([['Select gender', ''], ['Male', 'male'], ['Female', 'female'], ['Other', 'other']], @profile.gender), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500" %>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Looking for</label>
      <%= f.select :looking_for, options_for_select([['Select preference', ''], ['Male', 'male'], ['Female', 'female'], ['Everyone', 'everyone']], @profile.looking_for), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-pink-500 focus:ring-pink-500" %>
    </div>
  </div>
  
  <!-- Interests -->
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Interests</label>
    <div class="grid grid-cols-3 gap-2">
      <% Interest.all.each do |interest| %>
        <label class="inline-flex items-center">
          <%= check_box_tag "profile[interest_ids][]", interest.id, @profile.interest_ids.include?(interest.id), class: "rounded border-gray-300 text-pink-600 shadow-sm focus:border-pink-500 focus:ring-pink-500" %>
          <span class="ml-2 text-sm text-gray-700"><%= interest.name %></span>
        </label>
      <% end %>
    </div>
  </div>
  
  <!-- Submit -->
  <div class="flex justify-end">
    <%= f.submit "Save Profile", class: "bg-pink-500 text-white px-6 py-2 rounded-md hover:bg-pink-600 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2" %>
  </div>
<% end %>