<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Your Matches</h1>
  
  <% if @matches.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @matches.each do |match| %>
        <% other_user = match.other_user(current_user) %>
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition cursor-pointer"
             onclick="window.location='<%= match_messages_path(match) %>'">
          
          <div class="relative">
            <% if other_user.profile.photo? %>
              <%= image_tag other_user.profile.photo.url(:medium), class: "w-full h-48 object-cover" %>
            <% else %>
              <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400 text-4xl">📷</span>
              </div>
            <% end %>
            
            <!-- Online Status -->
            <div class="absolute top-2 right-2">
              <div class="flex items-center space-x-1 bg-white rounded-full px-2 py-1 shadow">
                <div class="w-2 h-2 <%= other_user.online? ? 'bg-green-500' : 'bg-gray-400' %> rounded-full"></div>
                <span class="text-xs"><%= other_user.online? ? 'Online' : 'Offline' %></span>
              </div>
            </div>
          </div>
          
          <div class="p-4">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-semibold"><%= other_user.profile.name %></h3>
              <span class="text-sm text-gray-500"><%= time_ago_in_words(match.updated_at) %> ago</span>
            </div>
            
            <p class="text-gray-600 mb-4"><%= other_user.profile.location %></p>
            
            <!-- Last Message -->
            <% if match.last_message %>
              <div class="bg-gray-50 rounded p-3 mb-4">
                <p class="text-sm text-gray-700 font-medium"><%= match.last_message.user.profile.name %>:</p>
                <p class="text-sm text-gray-600"><%= match.last_message.content.truncate(60) %></p>
              </div>
            <% end %>
            
            <!-- Interests -->
            <div class="flex flex-wrap gap-1">
              <% other_user.profile.interests.limit(3).each do |interest| %>
                <span class="bg-pink-100 text-pink-800 text-xs px-2 py-1 rounded"><%= interest.name %></span>
              <% end %>
            </div>
            
            <div class="mt-4 flex justify-end">
              <span class="text-pink-500 text-sm flex items-center">
                Send Message <span class="ml-1">→</span>
              </span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Pagination -->
    <div class="mt-8">
      <%= paginate @matches %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">💔</div>
      <h2 class="text-2xl font-semibold text-gray-700 mb-2">No matches yet</h2>
      <p class="text-gray-500 mb-6">Start browsing profiles and like someone to get matches!</p>
      <%= link_to "Browse Profiles", browse_profiles_path, class: "bg-pink-500 text-white px-6 py-3 rounded-full hover:bg-pink-600" %>
    </div>
  <% end %>
</div>