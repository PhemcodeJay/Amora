<%# app/views/dashboard/index.html.erb %>
<div class="container mx-auto px-4 py-8">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Left Column - Suggestions -->
    <div class="md:col-span-1">
      <h2 class="text-2xl font-bold mb-4">Suggested Matches</h2>
      <div class="space-y-4">
        <% @suggestions.each do |profile| %>
          <div class="bg-white rounded-lg shadow p-4">
            <% if profile.photo? %>
              <%= image_tag profile.photo.url(:thumb), class: "w-16 h-16 rounded-full mx-auto" %>
            <% end %>
            <h3 class="text-lg font-semibold text-center mt-2"><%= profile.name %>, <%= profile.age %></h3>
            <p class="text-gray-600 text-center text-sm"><%= profile.location %></p>
            <div class="flex justify-center mt-4">
              <%= button_to "Like", likes_path(user_id: profile.user_id), method: :post, class: "bg-pink-500 text-white px-4 py-2 rounded-full hover:bg-pink-600" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Middle Column - Matches -->
    <div class="md:col-span-1">
      <h2 class="text-2xl font-bold mb-4">Your Matches</h2>
      <div class="space-y-4">
        <% @matches.each do |match| %>
          <% other_user = match.other_user(current_user) %>
          <div class="bg-white rounded-lg shadow p-4 cursor-pointer hover:shadow-lg transition" 
               onclick="window.location='<%= match_messages_path(match) %>'">
            <div class="flex items-center space-x-4">
              <% if other_user.profile.photo? %>
                <%= image_tag other_user.profile.photo.url(:thumb), class: "w-12 h-12 rounded-full" %>
              <% end %>
              <div class="flex-1">
                <h3 class="font-semibold"><%= other_user.profile.name %></h3>
                <p class="text-gray-600 text-sm">
                  <%= match.last_message&.content&.truncate(30) || "No messages yet" %>
                </p>
              </div>
              <span class="text-xs text-gray-500">
                <%= time_ago_in_words(match.last_message&.created_at || match.created_at) %> ago
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Right Column - Recent Messages -->
    <div class="md:col-span-1">
      <h2 class="text-2xl font-bold mb-4">Recent Messages</h2>
      <div class="bg-white rounded-lg shadow p-4">
        <% @messages.each do |message| %>
          <div class="border-b last:border-0 py-3">
            <div class="flex items-center space-x-2">
              <span class="font-semibold"><%= message.user.profile.name %>:</span>
              <span class="text-gray-700 text-sm"><%= message.content.truncate(50) %></span>
            </div>
            <span class="text-xs text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>